{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Toolkit",
  "version": "1.0.0",
  "identifier": "com.janrone.codextoolkit",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Codex Toolkit",
        "width": 356,
        "height": 496,
        "minWidth": 356,
        "minHeight": 496,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "minimizable": true,
        "skipTaskbar": false,
        "closable": true,
        "transparent": false,
        "decorations": true,
        "shadow": true,
        "alwaysOnTop": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": "all"
  }
}
